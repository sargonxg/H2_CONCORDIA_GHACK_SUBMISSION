# ═══════════════════════════════════════════════════════════════════════════
# CONCORDIA Environment Configuration
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Never commit .env.local to version control.
# In production (Cloud Run), inject secrets via --set-secrets and
# plain env vars via --set-env-vars. Do not bake credentials into the image.
# ═══════════════════════════════════════════════════════════════════════════


# ── Authentication Mode ─────────────────────────────────────────────────
#
# CONCORDIA supports two authentication modes for the Gemini API:
#
#   Option A: Vertex AI with a GCP Service Account (recommended for production)
#   Option B: Gemini Developer API Key (simpler, good for development/testing)
#
# Uncomment and fill in the block that matches your setup.
# ─────────────────────────────────────────────────────────────────────────


# ── Option A: Vertex AI (Service Account) ───────────────────────────────
#
# Paste the full JSON content of your GCP service account key as a
# single-line string (the server writes it to /tmp at startup and sets
# GOOGLE_APPLICATION_CREDENTIALS for the Google Auth library).
#
# To create a service account key:
#   1. Go to https://console.cloud.google.com/iam-admin/serviceaccounts
#   2. Create a service account with role: roles/aiplatform.user
#   3. Create a JSON key and download it
#   4. Minify to one line: jq -c . key.json
#   5. Paste the result as the value below (inside single quotes)
#
# In Cloud Run production, store this in Secret Manager:
#   gcloud secrets create concordia-sa-key --data-file=key.json
#   # then use --set-secrets "GOOGLE_SERVICE_ACCOUNT_JSON=concordia-sa-key:latest"
#
GOOGLE_SERVICE_ACCOUNT_JSON='{...}'

# Google Cloud project ID.
# Must have the Vertex AI API enabled:
#   gcloud services enable aiplatform.googleapis.com --project=your-project-id
#
GOOGLE_CLOUD_PROJECT=your-project-id

# Vertex AI region.
# The Gemini Live Audio model is available in us-central1.
# Full list: https://cloud.google.com/vertex-ai/generative-ai/docs/learn/locations
#
GOOGLE_CLOUD_LOCATION=us-central1


# ── Option B: Gemini Developer API Key ──────────────────────────────────
#
# Simpler setup — no GCP project required. Suitable for development,
# testing, and personal use. Not recommended for production (no VPC,
# no IAM, rate limits apply).
#
# Get your key at: https://aistudio.google.com/
#
# To use this mode, uncomment the two lines below AND comment out (or
# remove) GOOGLE_SERVICE_ACCOUNT_JSON and GOOGLE_CLOUD_PROJECT above.
#
# USE_VERTEX_AI=false
# GEMINI_API_KEY=your-api-key-here


# ── Model Configuration (optional overrides) ────────────────────────────
#
# Override the default AI models if you need a specific version or want
# to test a preview model. Leave commented to use the built-in defaults.
#
# Live audio model (used for real-time mediation sessions via WebSocket).
# Vertex AI default:  gemini-live-2.5-flash-native-audio
# API key default:    gemini-2.5-flash-native-audio-preview-12-2025
#
# MODEL_LIVE=gemini-live-2.5-flash-native-audio

# Text model (used for /api/chat, /api/extract, /api/analyze, /api/research).
# Default: gemini-2.0-flash
#
# MODEL_TEXT=gemini-2.0-flash

# Text-to-speech model (used for /api/tts).
# Default: gemini-2.5-flash-preview-tts
#
# MODEL_TTS=gemini-2.5-flash-preview-tts

# Transcription model (used for /api/transcribe).
# Default: gemini-2.0-flash
#
# MODEL_TRANSCRIBE=gemini-2.0-flash


# ── Runtime ─────────────────────────────────────────────────────────────
#
# Set NODE_ENV=production in deployed environments.
# The server reads PORT to know which port to listen on (default: 8080).
# Cloud Run injects PORT=8080 automatically; you do not need to set it.
#
# NODE_ENV=production
# PORT=8080
